---
import DarkModeToggle from '../components/DarkModeToggle.astro';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
}

const {
  title,
  description = 'ドラゴン桜２を起点にした勉強法・名言・感想ブログ',
  ogType = 'website',
  ogImage,
} = Astro.props;

const siteTitle = 'Dragon Blog';
const siteUrl = 'https://ima9036282179-art.github.io/imanari-blog';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const canonicalUrl = Astro.url.href;
const pageTitle = `${title} | ${siteTitle}`;
const ogImageUrl = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`)
  : `${siteUrl}/images/dragon02.jpg`;

const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteTitle,
  url: `${siteUrl}/`,
  description: 'ドラゴン桜２を起点にした勉強法・名言・感想ブログ',
});
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="HeSG_S2uRzKa0CLFWE1pbLsDr9k_WIXm3B2gFMN3kv8" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OGP -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="alternate" type="application/rss+xml" title="Dragon Blog RSS" href={`${base}rss.xml`} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Noto+Serif+JP:wght@700;900&display=swap" rel="stylesheet" />

    <title>{pageTitle}</title>

    <!-- WebSite 構造化データ -->
    <script type="application/ld+json" set:html={websiteSchema} />

    <!-- 各ページ固有タグ（記事の JSON-LD など） -->
    <slot name="head" />

    <!-- ダークモード FOUC 防止 -->
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', saved || preferred);
      })();
    </script>
  </head>
  <body>
    <header class="site-header" id="site-header">
      <div class="header-inner">
        <a href={base} class="site-logo">
          <span class="site-logo-icon">🐉</span>
          <span class="site-title">Dragon Blog</span>
        </a>
        <nav class="site-nav">
          <a href={base}>ホーム</a>
          <a href={`${base}tags/`}>タグ</a>
          <a href={`${base}about/`}>About</a>
          <a href={`${base}newsletter/`}>📬 購読</a>
          <a href={`${base}search/`}>🔍 検索</a>
          <a href={`${base}fortune/`}>🔮 占い</a>
          <DarkModeToggle />
        </nav>
      </div>
    </header>

    <!-- フルワイドスロット（ヒーローバナーなど） -->
    <slot name="full-width" />

    <main class="site-wrapper">
      <slot />
    </main>

    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Dragon Blog. Built with Astro.</p>
      <div class="footer-sns">
        <a href="https://x.com/" class="footer-sns-btn" target="_blank" rel="noopener">𝕏 フォローする</a>
        <a href={`${base}newsletter/`} class="footer-sns-btn">📬 メール購読</a>
        <a href={`${base}rss.xml`} class="footer-sns-btn">RSS</a>
      </div>
    </footer>

    <!-- トップに戻るボタン -->
    <button class="back-to-top" id="backToTop" aria-label="トップへ戻る">↑</button>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  // ヘッダー スクロール時半透明化
  const header = document.getElementById('site-header');
  function updateHeader() {
    if (window.scrollY > 20) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // トップに戻るボタン
  const backToTop = document.getElementById('backToTop');
  function updateBackToTop() {
    if (window.scrollY > 320) {
      backToTop?.classList.add('visible');
    } else {
      backToTop?.classList.remove('visible');
    }
  }
  window.addEventListener('scroll', updateBackToTop, { passive: true });
  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // スクロール フェードイン（IntersectionObserver）
  const fadeEls = document.querySelectorAll('.fade-in-up');
  if (fadeEls.length > 0) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    fadeEls.forEach(el => io.observe(el));
  }
</script>

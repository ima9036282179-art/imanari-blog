---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout
  title="30日勉強チャレンジ｜桜木建二と一緒に習慣を作る【ドラゴン桜2】"
  description="ドラゴン桜2の桜木建二メソッドをベースにした30日間の勉強チャレンジ。毎日1つのタスクをこなして習慣化。進捗は自動保存されます。"
>
  <div class="challenge-page">
    <div class="challenge-hero">
      <p class="challenge-label">🐉 ドラゴン桜2 × 習慣化</p>
      <h1 class="challenge-title">30日勉強<br>チャレンジ</h1>
      <p class="challenge-desc">桜木建二のメソッドをもとに設計した30日間のチャレンジ。毎日1つだけ実行してください。積み上げた事実だけが、自信になります。</p>
    </div>

    <div class="challenge-progress-wrap">
      <div class="challenge-progress-bar" id="challengeProgress" style="width:0%"></div>
    </div>
    <p class="challenge-progress-text"><span id="doneCount">0</span> / 30 日 完了</p>

    <div class="challenge-quote" id="challengeQuote">
      <p class="cq-text">「逆転は、いつだって可能だ。ただし、今から始めた奴だけにな。」</p>
      <p class="cq-from">— 桜木建二</p>
    </div>

    <div class="challenge-grid" id="challengeGrid"></div>

    <div class="challenge-share" id="challengeShareArea" style="display:none;">
      <p class="challenge-share-label">30日達成！シェアする</p>
      <button id="shareComplete" class="share-btn share-x">𝕏 でシェア</button>
    </div>

    <button class="challenge-reset-btn" id="resetBtn">最初からやり直す</button>

    <div class="challenge-related">
      <h2 class="challenge-related-title">チャレンジを深める</h2>
      <div class="challenge-related-grid">
        <a href={`${base}blog/study-habit-small-start/`} class="cr-card">
          <span>📚</span>
          <span>「5分から始める」習慣化の科学</span>
        </a>
        <a href={`${base}blog/motivation-not-coming-out/`} class="cr-card">
          <span>🔥</span>
          <span>やる気が出ない3つの本当の原因</span>
        </a>
        <a href={`${base}study-template/`} class="cr-card">
          <span>📋</span>
          <span>勉強計画テンプレートを印刷する</span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
const tasks = [
  { day: 1,  quote: "「10分だけやれ。10分やって嫌ならやめていい。」", task: "今日から取り組みたい勉強・目標を紙に書く", category: "設計" },
  { day: 2,  quote: "「なぜ東大に行きたいんだ？」", task: "「なぜその勉強をするのか」を3行で書き出す", category: "動機" },
  { day: 3,  quote: "「方法が間違っているだけだ。」", task: "今使っている勉強法を1つ選び、改善点を考える", category: "方法" },
  { day: 4,  quote: "「一夜漬けで覚えたものは、一夜で忘れる。」", task: "3日前に勉強した内容を何も見ずに思い出してみる", category: "記憶" },
  { day: 5,  quote: "「やった量だけが、本番で自信になる。」", task: "今日の勉強時間を記録する（何分でもいい）", category: "記録" },
  { day: 6,  quote: "「自分だけの武器を磨け。」", task: "自分の「得意な勉強の仕方」を1つ言語化する", category: "強み" },
  { day: 7,  quote: "「逆転は、いつだって可能だ。」", task: "1週間の振り返り。できたこと・できなかったことを書く", category: "振返" },
  { day: 8,  quote: "「人に教えられないなら、まだ本当には理解していない。」", task: "今週学んだことを誰かに5分で説明する（一人でもOK）", category: "復習" },
  { day: 9,  quote: "「問いを立てられる人間が、時代を作る。」", task: "今勉強していることに「なぜ？」を3回繰り返す", category: "思考" },
  { day: 10, quote: "「10分だけやれ。」", task: "苦手だと思っている分野を10分だけ触れてみる", category: "挑戦" },
  { day: 11, quote: "「環境が人を変える。」", task: "勉強するデスクの上を片付けて、不要なものをなくす", category: "環境" },
  { day: 12, quote: "「諦めた瞬間、試合終了だ。」", task: "今日は「絶対にやめない」と決めて最低1問解く", category: "継続" },
  { day: 13, quote: "「本気になるのが怖いのは、本気でやって失敗したくないからだ。」", task: "難しいと思っていた問題に本気で向き合う", category: "挑戦" },
  { day: 14, quote: "「お前たちは証明した。人間は変われる。」", task: "2週間の振り返り。何が変わったか書き出す", category: "振返" },
  { day: 15, quote: "「弱さを知っている人間が、本当に強くなれる。」", task: "自分の「苦手分野」を1つ正直に書き出し、対策を1行考える", category: "分析" },
  { day: 16, quote: "「やった量だけが、本番で自信になる。」", task: "今日の勉強を始める前にタイマーをセットする（25分）", category: "集中" },
  { day: 17, quote: "「一夜漬けで覚えたものは、一夜で忘れる。」", task: "1週間前に勉強した内容を復習する", category: "記憶" },
  { day: 18, quote: "「もっと人を頼れ。」", task: "わからない問題を調べる・解説を読む（一人で悩みすぎない）", category: "学習" },
  { day: 19, quote: "「責任の重さが、人を本気にさせる。」", task: "「いつまでに何を達成するか」を宣言する（SNS・手帳・誰かに話す）", category: "宣言" },
  { day: 20, quote: "「逆転は、いつだって可能だ。」", task: "今日は少し難しい問題・レベルに挑戦する", category: "挑戦" },
  { day: 21, quote: "「諦めた瞬間、試合終了だ。」", task: "3週間の振り返り。続けてきた自分を褒める", category: "振返" },
  { day: 22, quote: "「人に教えられないなら、まだ本当には理解していない。」", task: "今週学んだことをノート1ページにまとめる", category: "整理" },
  { day: 23, quote: "「自分だけの武器を磨け。」", task: "得意分野をさらに深掘りする（1テーマ30分集中）", category: "強み" },
  { day: 24, quote: "「やる気が出ないのは意志の問題じゃない。構造の問題だ。」", task: "今の勉強スケジュールを見直し、続けやすい形に修正する", category: "設計" },
  { day: 25, quote: "「問いを立てられる人間が、時代を作る。」", task: "今学んでいることを実生活や仕事にどう活かせるか考える", category: "応用" },
  { day: 26, quote: "「本気になるのが怖いのは、本気でやって失敗したくないからだ。」", task: "模試・過去問・実力テストを1つ受けてみる", category: "実力" },
  { day: 27, quote: "「一夜漬けで覚えたものは、一夜で忘れる。」", task: "2週間前の内容を復習。どれくらい覚えているか確認する", category: "記憶" },
  { day: 28, quote: "「お前たちは証明した。人間は変われる。」", task: "28日間の成長を振り返り、スタート時との差を書き出す", category: "振返" },
  { day: 29, quote: "「逆転は、いつだって可能だ。ただし、今から始めた奴だけにな。」", task: "30日後の次の目標を設定する", category: "目標" },
  { day: 30, quote: "「お前たちは証明した。どんな状況からでも、人間は変われる。」", task: "30日間完走おめでとう。今日の気持ちを紙に書き残す", category: "完走" },
];

const quoteEl = document.getElementById('challengeQuote')!;
const gridEl = document.getElementById('challengeGrid')!;
const doneCountEl = document.getElementById('doneCount')!;
const progressEl = document.getElementById('challengeProgress') as HTMLElement;
const shareArea = document.getElementById('challengeShareArea')!;

const STORAGE_KEY = 'challenge30_done';

function loadDone(): Set<number> {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? new Set(JSON.parse(raw) as number[]) : new Set();
  } catch { return new Set(); }
}

function saveDone(done: Set<number>) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify([...done]));
}

let done = loadDone();

function updateProgress() {
  const count = done.size;
  doneCountEl.textContent = String(count);
  progressEl.style.width = (count / 30 * 100) + '%';
  shareArea.style.display = count === 30 ? 'block' : 'none';
}

function getLastDoneTask() {
  if (done.size === 0) return tasks[0];
  const maxDay = Math.max(...done);
  return tasks.find(t => t.day === maxDay) ?? tasks[0];
}

function renderGrid() {
  gridEl.innerHTML = tasks.map(t => {
    const isDone = done.has(t.day);
    return `
      <div class="challenge-card ${isDone ? 'done' : ''}" data-day="${t.day}">
        <div class="cc-top">
          <span class="cc-day">Day ${t.day}</span>
          <span class="cc-cat">${t.category}</span>
          ${isDone ? '<span class="cc-check">✓</span>' : ''}
        </div>
        <p class="cc-task">${t.task}</p>
        <button class="cc-btn ${isDone ? 'done' : ''}" data-day="${t.day}">
          ${isDone ? '完了済み' : 'やった！'}
        </button>
      </div>
    `;
  }).join('');

  gridEl.querySelectorAll('.cc-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const day = Number((e.currentTarget as HTMLElement).dataset.day);
      if (done.has(day)) {
        done.delete(day);
      } else {
        done.add(day);
        const task = tasks.find(t => t.day === day);
        if (task) {
          (quoteEl.querySelector('.cq-text') as HTMLElement).textContent = task.quote;
        }
      }
      saveDone(done);
      renderGrid();
      updateProgress();
    });
  });
}

document.getElementById('resetBtn')!.addEventListener('click', () => {
  if (confirm('進捗をリセットしますか？')) {
    done = new Set();
    saveDone(done);
    renderGrid();
    updateProgress();
  }
});

document.getElementById('shareComplete')!.addEventListener('click', () => {
  const text = `ドラゴン桜2の桜木建二メソッドで「30日勉強チャレンジ」を達成しました🎉\n\n#ドラゴン桜2 #30日チャレンジ #勉強習慣`;
  window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(location.href)}`, '_blank');
});

renderGrid();
updateProgress();
</script>

<style is:global>
.challenge-page { max-width: 760px; margin: 0 auto; padding: 2rem 0 5rem; }

.challenge-hero { text-align: center; margin-bottom: 2rem; }
.challenge-label { font-size: 0.85rem; color: var(--accent); font-weight: 700; letter-spacing: 0.05em; margin-bottom: 0.5rem; }
.challenge-title { font-family: 'Noto Serif JP', serif; font-size: 2rem; font-weight: 900; line-height: 1.4; margin: 0 0 0.75rem; color: var(--text); }
.challenge-desc { color: var(--text-muted); font-size: 0.92rem; line-height: 1.8; max-width: 520px; margin: 0 auto; }

.challenge-progress-wrap { background: var(--border); border-radius: 99px; height: 8px; margin-bottom: 0.4rem; overflow: hidden; }
.challenge-progress-bar { height: 100%; background: linear-gradient(90deg, #450A0A, #DC2626); border-radius: 99px; transition: width 0.4s ease; }
.challenge-progress-text { font-size: 0.85rem; color: var(--text-muted); text-align: right; margin-bottom: 1.5rem; }

.challenge-quote { background: var(--bg-card); border-left: 4px solid var(--accent); border-radius: 0 12px 12px 0; padding: 1rem 1.25rem; margin-bottom: 2rem; }
.cq-text { font-size: 0.95rem; font-weight: 700; color: var(--text); font-style: italic; margin: 0 0 0.3rem; line-height: 1.7; }
.cq-from { font-size: 0.75rem; color: var(--accent); margin: 0; font-weight: 700; }

.challenge-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 2rem; }

.challenge-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1rem; transition: border-color 0.15s; }
.challenge-card.done { border-color: #16a34a; background: rgba(22,163,74,0.05); }

.cc-top { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
.cc-day { font-size: 0.75rem; font-weight: 900; color: var(--accent); }
.cc-cat { font-size: 0.65rem; background: var(--border); color: var(--text-muted); padding: 0.1rem 0.5rem; border-radius: 99px; }
.cc-check { font-size: 0.8rem; color: #16a34a; font-weight: 900; margin-left: auto; }
.cc-task { font-size: 0.8rem; color: var(--text); line-height: 1.6; margin: 0 0 0.75rem; min-height: 2.5rem; }
.cc-btn { width: 100%; padding: 0.45rem; border-radius: 8px; font-size: 0.78rem; font-weight: 700; cursor: pointer; border: 1px solid var(--border); background: var(--bg); color: var(--text); font-family: 'Noto Sans JP', sans-serif; transition: background 0.15s, border-color 0.15s, color 0.15s; }
.cc-btn:hover:not(.done) { background: var(--accent); border-color: var(--accent); color: #fff; }
.cc-btn.done { background: rgba(22,163,74,0.1); border-color: #16a34a; color: #16a34a; }

.challenge-share { text-align: center; margin-bottom: 1.5rem; }
.challenge-share-label { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.6rem; }
.share-btn { padding: 0.6rem 1.5rem; border-radius: 8px; font-weight: 700; font-size: 0.85rem; cursor: pointer; border: none; font-family: 'Noto Sans JP', sans-serif; }
.share-x { background: #000; color: #fff; }

.challenge-reset-btn { display: block; margin: 0 auto 2.5rem; background: none; border: 1px solid var(--border); color: var(--text-muted); padding: 0.5rem 1.5rem; border-radius: 8px; font-size: 0.8rem; cursor: pointer; font-family: 'Noto Sans JP', sans-serif; }

.challenge-related { border-top: 1px solid var(--border); padding-top: 2rem; }
.challenge-related-title { font-size: 0.9rem; font-weight: 700; color: var(--text-muted); margin-bottom: 1rem; text-align: center; }
.challenge-related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
.cr-card { display: flex; flex-direction: column; align-items: center; gap: 0.4rem; padding: 1rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; text-decoration: none; color: var(--text); font-size: 0.8rem; text-align: center; font-weight: 600; line-height: 1.5; transition: border-color 0.15s, transform 0.15s; }
.cr-card:hover { border-color: var(--accent); transform: translateY(-2px); }
.cr-card span:first-child { font-size: 1.4rem; }

@media (max-width: 600px) {
  .challenge-grid { grid-template-columns: 1fr 1fr; }
  .challenge-related-grid { grid-template-columns: 1fr; }
  .challenge-title { font-size: 1.6rem; }
}
</style>

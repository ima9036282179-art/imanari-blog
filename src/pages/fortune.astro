---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ドラゴン桜２ ワンオラクル占い｜桜木建二からの今日のメッセージ" description="桜木建二の言葉が今日のあなたへのメッセージ。20枚のタロットカードから1枚引いて、今日の指針を受け取ろう。">
  <div class="fortune-outer">
    <div class="fortune-wrap">
      <h1 class="fortune-title">🔮 ドラゴン桜２ ワンオラクル</h1>
      <p class="fortune-desc">心を静めて、桜木建二からのメッセージを受け取ってください。</p>

    <div class="card-area">
      <div class="card" id="card">
        <div class="card-inner">
          <div class="card-front">
            <div class="front-header">✦ DRAGON ZAKURA ✦</div>
            <div class="front-mark">？</div>
            <div class="front-footer">― 桜木建二 ―</div>
          </div>
          <div class="card-back-face" id="cardContent">
          </div>
        </div>
      </div>
    </div>

    <button class="draw-btn" id="drawBtn">カードを引く</button>
    <button class="reset-btn" id="resetBtn" style="display:none;">もう一度引く</button>

    <div class="oracle-result" id="oracleResult" style="display:none;">
      <p class="oracle-label">✦ 今日のメッセージ ✦</p>
      <p class="oracle-text" id="oracleText"></p>
    </div>
    </div><!-- /.fortune-wrap -->

    <aside class="fortune-sidebar">
      <div class="sidebar-card">
        <p class="sidebar-label">🎬 キャラ診断</p>
        <h2 class="sidebar-title">あなたは東大専科の<br>誰タイプ？</h2>
        <p class="sidebar-desc">8問の質問に答えるだけで、あなたに最も近いキャラクターと勉強法がわかります。</p>
        <div class="sidebar-types">
          <span>🏸 楓</span>
          <span>🐛 健太</span>
          <span>🌸 麻里</span>
          <span>📐 藤井</span>
          <span>🔥 瀬戸</span>
        </div>
        <a href="/imanari-blog/quiz/" class="sidebar-btn">診断スタート →</a>
        <p class="sidebar-note">無料・約2分</p>
      </div>
    </aside>
  </div><!-- /.fortune-outer -->
</BaseLayout>

<script>
  const cards = [
    {
      numeral: 'Ⅰ',
      quote: '「バカとブスこそ東大へ行け」',
      desc: '見た目や偏差値で人生を諦めるな。シリーズを貫く代名詞的な一言。',
      oracle: '今日のあなたへ——自分を過小評価するのをやめる日です。常識や先入観が作り出した「壁」はあなたの想像の中にしか存在しません。大きな目標に向けて、今すぐ一歩踏み出してください。'
    },
    {
      numeral: 'Ⅱ',
      quote: '「ルールは賢い奴が自分に都合よく作ってんだ。だから勉強しろ。ルールを作る側に回れ。」',
      desc: '社会の本質を突いた言葉。勉強の意義を根本から問い直させてくれる。',
      oracle: '今日のあなたへ——あなたはまだ「与えられたルール」の中で動いていませんか？知識を身につけることで、ゲームのルールを変える側に回れます。今日は学ぶことに時間を使いましょう。'
    },
    {
      numeral: 'Ⅲ',
      quote: '「できない理由を探すな。できる方法を探せ。」',
      desc: '言い訳をやめ、行動に転換するきっかけをくれる一言。',
      oracle: '今日のあなたへ——あなたの前に立ちはだかる壁は、実は薄い紙一枚かもしれません。「どうすればできるか」だけを考えてください。答えは必ず見つかります。'
    },
    {
      numeral: 'Ⅳ',
      quote: '「諦めたらそこで試合終了じゃない。諦めた瞬間から、負けが始まるんだ。」',
      desc: '終わりではなく「始まり」として捉える逆転の発想。',
      oracle: '今日のあなたへ——少し疲れを感じているかもしれません。しかし今日がその分岐点です。諦める前に、もう一度だけ立ち上がってみてください。未来はあなたの選択の先にあります。'
    },
    {
      numeral: 'Ⅴ',
      quote: '「お前らが逃げているのは失敗することじゃない。本気になることだ。」',
      desc: '「本気になること」を恐れていることを鋭く指摘した言葉。',
      oracle: '今日のあなたへ——本気で向き合うことを、どこかで怖れていませんか？傷つくことを恐れて全力を出し惜しみしているなら、今日がその呪縛を解く日です。'
    },
    {
      numeral: 'Ⅵ',
      quote: '「勉強は才能じゃない。やり方と時間の問題だ。」',
      desc: '「自分には無理」という思い込みを崩す言葉。',
      oracle: '今日のあなたへ——「自分には向いていない」という思い込みを捨ててください。正しい方法で十分な時間をかければ、あなたは必ず成果を出せます。今日は方法を見直す日です。'
    },
    {
      numeral: 'Ⅶ',
      quote: '「東大に受かるかどうかは、結局やるかやらないかだ。」',
      desc: 'シンプルだが核心を突く言葉。どんな問題もこれに尽きる。',
      oracle: '今日のあなたへ——複雑に考えすぎていませんか？突き詰めれば、あとはやるかやらないかだけです。今日は考える前に動いてみてください。'
    },
    {
      numeral: 'Ⅷ',
      quote: '「模試の点数はお前の実力じゃない。今の状態を示しているだけだ。」',
      desc: '結果に一喜一憂せず、プロセスを大切にすることの本質。',
      oracle: '今日のあなたへ——最近の結果に落ち込んでいるなら、それはあなたの「今の状態」にすぎません。過去の結果は変えられませんが、今日からの行動は変えられます。'
    },
    {
      numeral: 'Ⅸ',
      quote: '「人生に必要なのは、正しい努力と正しい方向性だ。」',
      desc: 'がむしゃらに頑張るだけでなく、戦略的に動く重要性。',
      oracle: '今日のあなたへ——頑張っているのに成果が出ないと感じているなら、方向性を見直す時かもしれません。量より質。今日は「何のために」を問い直してみてください。'
    },
    {
      numeral: 'Ⅹ',
      quote: '「教えることは最高の学習法だ。教えられないなら、まだ本当には理解していない。」',
      desc: 'アウトプットの重要性を端的に表した名言。',
      oracle: '今日のあなたへ——インプットばかりになっていませんか？誰かに説明する、書き出す、声に出す——アウトプットが知識を本物にします。今日は教えることを意識してみてください。'
    },
    {
      numeral: 'Ⅺ',
      quote: '「環境のせいにするな。環境を変えるのがお前の仕事だ。」',
      desc: '境遇を言い訳にしない強さを与えてくれる言葉。',
      oracle: '今日のあなたへ——周囲の状況への不満があるなら、それを変える力はあなた自身の中にあります。今日、あなたにできる一つの行動で環境を変えてみましょう。'
    },
    {
      numeral: 'Ⅻ',
      quote: '「睡眠不足は最大の敵だ。寝ることも勉強のうちだ。」',
      desc: '根性論を否定し、科学的な学習を推奨する桜木らしい言葉。',
      oracle: '今日のあなたへ——無理をしすぎていませんか？体と頭を万全に整えることが、最大のパフォーマンスへの近道です。今日は意識的に休息を取りましょう。'
    },
    {
      numeral: 'XIII',
      quote: '「今のお前に必要なのは比較じゃなく前進だ。」',
      desc: '他人との比較をやめ、自分の成長にフォーカスする大切さ。',
      oracle: '今日のあなたへ——他の誰かと自分を比べて落ち込む必要はありません。昨日の自分と比べて、今日の自分が少しでも前に進んでいれば十分です。'
    },
    {
      numeral: 'XIV',
      quote: '「失敗は恥じゃない。挑戦しないことが恥だ。」',
      desc: 'チャレンジすることへの勇気をくれる言葉。',
      oracle: '今日のあなたへ——迷っているなら、挑戦してください。失敗しても、それはあなたが動いた証拠です。動かない後悔より、動いた失敗を選ぶ日です。'
    },
    {
      numeral: 'XV',
      quote: '「25分やったら5分休め。だらだら6時間より、集中した3時間の方が価値がある。」',
      desc: '効率的な学習時間の使い方を示した実践的な言葉。',
      oracle: '今日のあなたへ——長時間だらだら取り組むより、集中した短い時間の方が何倍もの成果を生みます。今日は時間を区切って、全力で集中してみてください。'
    },
    {
      numeral: 'XVI',
      quote: '「好きなことだけやって生きていけると思うな。嫌いなことを乗り越えた先に、本当にやりたいことが見えてくる。」',
      desc: '甘くない現実と向き合う覚悟を促す言葉。',
      oracle: '今日のあなたへ——今、避けていることはありますか？嫌なこと、苦手なことに向き合う先に、あなたの本当の可能性が待っています。今日、一つだけ向き合ってみてください。'
    },
    {
      numeral: 'XVII',
      quote: '「問題を解くな。問題を理解しろ。解き方を覚えても、問題が変われば使えない。」',
      desc: '丸暗記ではなく理解を重視する学習姿勢の本質。',
      oracle: '今日のあなたへ——表面的な解決策を探すより、根本を理解することが大切です。今日は「なぜそうなるのか」を一段深く掘り下げてみてください。'
    },
    {
      numeral: 'XVIII',
      quote: '「夢は見つけるものじゃなく、作るものだ。」',
      desc: '夢がないことを悩む人への力強いメッセージ。',
      oracle: '今日のあなたへ——やりたいことが見つからないと悩んでいるなら、それを「探す」のをやめてみてください。小さな行動の積み重ねが、気づけば夢になっています。'
    },
    {
      numeral: 'XIX',
      quote: '「逆転は、いつだって可能だ。ただし、今から始めた奴だけにな。」',
      desc: '希望と叱咤を同時に伝える、ドラゴン桜らしい言葉。',
      oracle: '今日のあなたへ——今から始めれば、まだ間に合います。遅すぎることはありません。ただし、動かなければ何も変わりません。今日が逆転のスタートです。'
    },
    {
      numeral: 'XX',
      quote: '「お前が変われば、周りも変わる。世界は外から変えるんじゃなく、内側から変わるんだ。」',
      desc: '自分自身の変革が世界を変えるという、ドラゴン桜の根底にあるメッセージ。',
      oracle: '今日のあなたへ——外の世界を変えようとする前に、まず自分自身を変えてみてください。あなたが変われば、不思議とあなたを取り巻く世界も変わり始めます。'
    }
  ];

  const card = document.getElementById('card');
  const drawBtn = document.getElementById('drawBtn');
  const resetBtn = document.getElementById('resetBtn');
  const cardContent = document.getElementById('cardContent');
  const oracleResult = document.getElementById('oracleResult');
  const oracleText = document.getElementById('oracleText');

  function drawCard() {
    const picked = cards[Math.floor(Math.random() * cards.length)];

    cardContent.innerHTML = `
      <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px 16px;box-sizing:border-box;">
        <div style="color:#c9a84c;font-size:9px;letter-spacing:3px;margin-bottom:6px;">✦ DRAGON ZAKURA ✦</div>
        <div style="color:#c9a84c;font-size:20px;font-weight:bold;margin-bottom:10px;">${picked.numeral}</div>
        <div style="border-top:1px solid #c9a84c;border-bottom:1px solid #c9a84c;padding:12px 4px;margin-bottom:10px;width:100%;">
          <p style="color:#f5e6c0;font-size:12px;font-weight:bold;line-height:1.8;margin:0;text-align:center;">${picked.quote}</p>
        </div>
        <p style="color:#b8a880;font-size:10px;line-height:1.6;margin:0 0 10px;text-align:center;">${picked.desc}</p>
        <div style="color:#c9a84c;font-size:10px;letter-spacing:2px;">― 桜木建二 ―</div>
      </div>
    `;

    oracleText.textContent = picked.oracle;

    card.classList.add('flipped');
    drawBtn.style.display = 'none';
    resetBtn.style.display = 'inline-block';
    oracleResult.style.display = 'block';
  }

  function resetCard() {
    card.classList.remove('flipped');
    drawBtn.style.display = 'inline-block';
    resetBtn.style.display = 'none';
    oracleResult.style.display = 'none';
    cardContent.innerHTML = '';
  }

  drawBtn.addEventListener('click', drawCard);
  resetBtn.addEventListener('click', resetCard);
</script>

<style>
  .fortune-outer {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .fortune-wrap {
    flex: 1;
    min-width: 0;
    text-align: center;
  }

  /* サイドバー：キャラ診断 */
  .fortune-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 5rem;
  }

  .sidebar-card {
    background: linear-gradient(160deg, #1a0533 0%, #2d1b69 100%);
    border: 1px solid #c9a84c;
    border-radius: 16px;
    padding: 1.5rem 1.25rem;
    text-align: center;
    box-shadow: 0 0 16px rgba(201,168,76,0.15);
  }

  .sidebar-label {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: #c9a84c;
    margin: 0 0 0.5rem;
    font-weight: 700;
  }

  .sidebar-title {
    font-size: 1rem;
    font-weight: 900;
    color: #f5e6c0;
    line-height: 1.5;
    margin: 0 0 0.75rem;
    font-family: 'Noto Serif JP', serif;
  }

  .sidebar-desc {
    font-size: 0.75rem;
    color: #b8a880;
    line-height: 1.7;
    margin: 0 0 1rem;
  }

  .sidebar-types {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .sidebar-types span {
    font-size: 0.7rem;
    background: rgba(201,168,76,0.15);
    border: 1px solid rgba(201,168,76,0.3);
    color: #c9a84c;
    padding: 0.2rem 0.5rem;
    border-radius: 99px;
  }

  .sidebar-btn {
    display: block;
    background: linear-gradient(135deg, #c9a84c, #e8c96e);
    color: #1a0533;
    font-weight: 900;
    font-size: 0.85rem;
    padding: 0.65rem 1rem;
    border-radius: 99px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.1s;
    margin-bottom: 0.5rem;
  }

  .sidebar-btn:hover { opacity: 0.85; transform: translateY(-2px); }

  .sidebar-note {
    font-size: 0.68rem;
    color: #b8a880;
    margin: 0;
  }

  @media (max-width: 700px) {
    .fortune-outer { flex-direction: column; }
    .fortune-sidebar { width: 100%; position: static; }
    .sidebar-card { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; text-align: left; }
    .sidebar-title { font-size: 0.95rem; }
    .sidebar-btn { white-space: nowrap; }
  }

  .fortune-title {
    font-size: 1.6rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .fortune-desc {
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    font-size: 0.95rem;
  }

  .card-area {
    perspective: 1000px;
    margin-bottom: 2rem;
  }

  .card {
    width: 260px;
    height: 380px;
    margin: 0 auto;
    cursor: pointer;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.8s ease;
  }

  .card.flipped {
    transform: rotateY(180deg);
  }

  .card-inner {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
  }

  .card-front,
  .card-back-face {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 12px;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    overflow: hidden;
  }

  .card-front {
    background: linear-gradient(160deg, #1a0533 0%, #2d1b69 50%, #1a0533 100%);
    border: 2px solid #c9a84c;
    box-shadow: 0 0 20px rgba(201,168,76,0.35);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    font-family: Georgia, serif;
  }

  .front-header {
    color: #c9a84c;
    font-size: 10px;
    letter-spacing: 3px;
  }

  .front-mark {
    color: #c9a84c;
    font-size: 4rem;
    font-weight: bold;
    opacity: 0.7;
  }

  .front-footer {
    color: #c9a84c;
    font-size: 10px;
    letter-spacing: 2px;
  }

  .card-back-face {
    background: linear-gradient(160deg, #1a0533 0%, #2d1b69 50%, #1a0533 100%);
    border: 2px solid #c9a84c;
    box-shadow: 0 0 20px rgba(201,168,76,0.35);
    transform: rotateY(180deg);
    font-family: Georgia, serif;
  }

  .draw-btn,
  .reset-btn {
    padding: 0.75rem 2.5rem;
    border-radius: 9999px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: opacity 0.2s, transform 0.1s;
  }

  .draw-btn {
    background: linear-gradient(135deg, #c9a84c, #e8c96e);
    color: #1a0533;
  }

  .reset-btn {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .draw-btn:hover,
  .reset-btn:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  .oracle-result {
    margin-top: 2rem;
    padding: 1.5rem;
    background: linear-gradient(160deg, #1a0533 0%, #2d1b69 100%);
    border: 1px solid #c9a84c;
    border-radius: 12px;
    box-shadow: 0 0 16px rgba(201,168,76,0.2);
  }

  .oracle-label {
    color: #c9a84c;
    font-size: 11px;
    letter-spacing: 3px;
    margin: 0 0 0.75rem;
  }

  .oracle-text {
    color: #f5e6c0;
    font-size: 0.9rem;
    line-height: 1.8;
    margin: 0;
    text-align: left;
  }
</style>

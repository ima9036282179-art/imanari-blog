---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../utils/readingTime';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const allTags = [...new Set(posts.flatMap(p => p.data.tags ?? []))];
---

<BaseLayout title="ホーム">
  <section class="hero">
    <h1 class="hero-title">My Blog</h1>
    <p class="hero-desc">Astro で作ったシンプルなブログです。</p>
  </section>

  <section class="profile-card">
    <img src={`${base}images/onepiece01_luffy.png`} alt="imanari" class="profile-avatar" />
    <div class="profile-body">
      <p class="profile-name">imanari</p>
      <p class="profile-bio">Claude Codeを使ってブログを作りました</p>
    </div>
  </section>

  <section>
    <!-- タグフィルター -->
    <div class="tag-filter" id="tagFilter">
      <button class="filter-btn active" data-tag="all">すべて</button>
      {allTags.map(tag => (
        <button class="filter-btn" data-tag={tag}>{tag}</button>
      ))}
    </div>

    <ul class="post-list" id="postList" role="list">
      {posts.map((post) => {
        const url = `${base}blog/${post.slug}/`;
        const date = post.data.pubDate.toLocaleDateString('ja-JP', {
          year: 'numeric', month: 'long', day: 'numeric',
        });
        const minutes = readingTime(post.body);
        const tagsJson = JSON.stringify(post.data.tags ?? []);
        return (
          <li data-tags={tagsJson}>
            <a href={url} class="post-card" style="display:block;text-decoration:none;">
              {post.data.category && <span class="category-badge">{post.data.category}</span>}
              <h2 class="post-card-title">{post.data.title}</h2>
              <p class="post-card-desc">{post.data.description}</p>
              <div class="post-card-meta">
                <time class="post-date" datetime={post.data.pubDate.toISOString()}>{date}</time>
                <span class="reading-time">📖 約{minutes}分</span>
                {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
    <p class="no-results" id="noResults" style="display:none;">該当する記事がありません。</p>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLLIElement>('#postList li');
  const noResults = document.getElementById('noResults')!;

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const selected = btn.dataset.tag!;
      let visible = 0;

      items.forEach(item => {
        const tags: string[] = JSON.parse(item.dataset.tags || '[]');
        const show = selected === 'all' || tags.includes(selected);
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      noResults.style.display = visible === 0 ? 'block' : 'none';
    });
  });
</script>

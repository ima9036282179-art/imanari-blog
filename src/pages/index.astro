---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="ホーム">
  <section class="hero">
    <h1 class="hero-title">My Blog</h1>
    <p class="hero-desc">Astro で作ったシンプルなブログです。</p>
  </section>

  <section>
    <p class="posts-heading">記事一覧</p>
    <ul class="post-list" role="list">
      {posts.map((post) => {
        const url = `${import.meta.env.BASE_URL}blog/${post.slug}/`;
        const date = post.data.pubDate.toLocaleDateString('ja-JP', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <li>
            <a href={url} class="post-card" style="display:block;text-decoration:none;">
              <h2 class="post-card-title">{post.data.title}</h2>
              <p class="post-card-desc">{post.data.description}</p>
              <div class="post-card-meta">
                <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                  {date}
                </time>
                {post.data.tags?.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>

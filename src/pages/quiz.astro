let current = 0;
const answers: string[] = new Array(questions.length).fill('');

function renderQuestion() {
  const q = questions[current];
  const area = document.getElementById('questionArea')!;
  const progress = ((current + 1) / questions.length) * 100;
  (document.getElementById('progressBar') as HTMLElement).style.width = progress + '%';
  (document.getElementById('progressText') as HTMLElement).textContent = `質問 ${current + 1} / ${questions.length}`;

  area.innerHTML = `
    <div class="question-card">
      <p class="question-text">Q${current + 1}. ${q.text}</p>
      <div class="options-list">
        ${q.options.map((opt, i) => {
          const letters = ['A', 'B', 'C', 'D', 'E'];
          return `
          <label class="option-label ${answers[current] === opt.type ? 'selected' : ''}">
            <input type="radio" name="q" value="${opt.type}" ${answers[current] === opt.type ? 'checked' : ''} />
            <span class="option-badge">${letters[i]}</span>
            <span class="option-text">${opt.text}</span>
          </label>
          `;
        }).join('')}
      </div>
    </div>
  `;

  area.querySelectorAll('input[name="q"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      answers[current] = (e.target as HTMLInputElement).value;
      area.querySelectorAll('.option-label').forEach(l => l.classList.remove('selected'));
      (e.target as HTMLInputElement).closest('.option-label')?.classList.add('selected');
      (document.getElementById('nextBtn') as HTMLButtonElement).disabled = false;
    });
  });

  (document.getElementById('prevBtn') as HTMLButtonElement).disabled = current === 0;
  (document.getElementById('nextBtn') as HTMLButtonElement).disabled = !answers[current];
  (document.getElementById('nextBtn') as HTMLButtonElement).textContent =
    current === questions.length - 1 ? '結果を見る ✨' : '次へ →';
}

function showResult() {

---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title="記事検索" description="ドラゴン桜2ブログの記事を検索できます。">
  <div class="search-wrap">
    <h1 class="search-heading">🔍 記事検索</h1>
    <div id="search"></div>
    <p class="search-note" id="searchNote">※ 検索インデックスはビルド後に有効になります。ローカル開発環境では動作しない場合があります。</p>
  </div>
</BaseLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>

<script define:vars={{ base }}>
  window.addEventListener('load', () => {
    if (typeof window.PagefindUI !== 'undefined') {
      new window.PagefindUI({
        element: '#search',
        showSubResults: true,
        translations: {
          placeholder: 'キーワードを入力…',
          zero_results: '「[SEARCH_TERM]」の検索結果はありません',
        },
      });
      document.getElementById('searchNote')?.remove();
    }
  });
</script>

<style>
  .search-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .search-heading {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.8rem;
    font-weight: 900;
    margin-bottom: 1.75rem;
  }

  .search-note {
    margin-top: 1rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }
</style>
